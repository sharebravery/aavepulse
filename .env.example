# Local PostgreSQL container. These are development-only defaults.
POSTGRES_DB=aavepulse
POSTGRES_USER=aavepulse
POSTGRES_PASSWORD=aavepulse
POSTGRES_PORT=5432

# Backend overrides. Leave Graph empty while AAVEPULSE_DEMO_MODE=true.
AAVEPULSE_DATABASE_DSN=host=127.0.0.1 user=aavepulse password=aavepulse dbname=aavepulse port=5432 sslmode=disable TimeZone=UTC
AAVEPULSE_DEMO_MODE=true
AAVEPULSE_GRAPH_ENDPOINT=
AAVEPULSE_GRAPH_API_KEY=
AAVEPULSE_JWT_SIGNING_KEY=replace-for-non-local-use

# Frontend development server.
VITE_API_BASE_URL=http://localhost:8040/api/v1
